BOT_ENABLED=false
ENABLED_SUBREDDITS=recipes,cooking
ALLOW_SOURCE_IMAGES=false
MAX_SOURCE_IMAGES=4
ARTIFACT_ROOT=artifacts
ARTIFACT_BASE_URL=http://localhost:8000/cards
IMAGEMAGICK_BINARY=magick
