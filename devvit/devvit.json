{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "recipebot-devgw",
  "server": {
    "entry": "dist/server/index.cjs"
  },
  "permissions": {
    "http": {
      "enable": true,
      "domains": [
        "recipebot.devgw.com"
      ]
    },
    "reddit": true
  },
  "triggers": {
    "onCommentCreate": "/internal/triggers/comment-create"
  },
  "settings": {
    "global": {
      "RECIPEBOT_BACKEND_URL": {
        "type": "string",
        "label": "RecipeBot backend URL",
        "defaultValue": "https://recipebot.devgw.com"
      },
      "RECIPEBOT_WEBHOOK_SECRET": {
        "type": "string",
        "label": "RecipeBot webhook HMAC secret",
        "isSecret": true
      }
    }
  },
  "dev": {
    "subreddit": "recipebot_devgw_dev"
  },
  "scripts": {
    "build": "npm run build",
    "dev": "npm run dev"
  },
  "sourceIgnores": [
    "tests/",
    "coverage/"
  ]
}